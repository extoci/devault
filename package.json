{
  "name": "devault-cli",
  "version": "0.1.1",
  "description": "d → the right dev command.",
  "type": "module",
  "bin": {
    "d": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsgo --noEmit && bun build src/cli.ts --target=bun --outfile=dist/cli.js && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "check": "tsgo --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260527.2",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "license": "MIT"
}
